# =============================================================================
# SyncWire Android — .gitignore
# =============================================================================
# Combines the GitHub Android template with Kotlin / Compose / modern
# Android Studio (Hedgehog+) conventions. Organized by category so it's
# obvious what each entry ignores and why.
# =============================================================================

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
# Anything generated by `./gradlew assemble`. Regenerable from source.
build/
.gradle/

# Native build (NDK / CMake)
.externalNativeBuild/
.cxx/

# -----------------------------------------------------------------------------
# Local / per-machine config (NEVER commit)
# -----------------------------------------------------------------------------
local.properties          # SDK path, machine-specific
keystore.properties       # signing key references
signing.properties        # alt signing config
*.jks                     # Java keystore (release signing keys)
*.keystore                # generic keystore files

# ProGuard mapping files sometimes leak signing info — keep mapping.txt in VCS,
# but ignore stacktrace-only outputs.
proguard/
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint/reports/

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
# IntelliJ IDEA + Android Studio
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code (if a contributor uses it)
.vscode/

# Eclipse
.classpath
.project
.settings/

# -----------------------------------------------------------------------------
# Kotlin
# -----------------------------------------------------------------------------
.kotlin/                  # Kotlin compiler caches (since K2 / 2.0+)

# -----------------------------------------------------------------------------
# OS noise
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# -----------------------------------------------------------------------------
# Editor swap / backup files
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
*.bak

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# Android outputs / packaging
# -----------------------------------------------------------------------------
*.apk
*.ap_
*.aab
*.apks
output-metadata.json
*.dex
*.class
bin/
gen/

# Captures (Profiler, Network, etc.)
captures/

# Profiling dumps
*.hprof

# -----------------------------------------------------------------------------
# Google / Firebase / Auth providers
# -----------------------------------------------------------------------------
google-services.json
# google-services.properties

# -----------------------------------------------------------------------------
# Fastlane
# -----------------------------------------------------------------------------
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md
fastlane/report.yaml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# Kept files (allowlist inside .gitignore)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
